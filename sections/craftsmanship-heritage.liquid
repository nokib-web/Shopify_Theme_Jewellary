{%- style -%}
  .craftsmanship-section-{{ section.id }} {
    padding: 120px 0;
    background-color: #ffffff;
  }
  .craftsmanship-container {
    position: relative;
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    padding: 0 40px;
  }
  .craftsmanship-container--reverse {
    flex-direction: row-reverse;
  }
  .craftsmanship-image-wrapper {
    width: 65%;
    position: relative;
  }
  .craftsmanship-image {
    width: 100%;
    height: 650px;
    object-fit: cover;
    display: block;
  }
  .craftsmanship-content-wrapper {
    width: 45%;
    position: absolute;
    right: 40px;
    background-color: #ffffff;
    padding: 80px 60px;
    border: 1px solid rgba(0,0,0,0.05);
    z-index: 2;
  }
  .craftsmanship-container--reverse .craftsmanship-content-wrapper {
    right: auto;
    left: 40px;
  }
  .craftsmanship-subtitle {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 3px;
    margin-bottom: 20px;
    color: #666;
  }
  .craftsmanship-title {
    font-size: 40px;
    font-family: var(--typeHeaderPrimary), serif;
    margin-bottom: 25px;
    line-height: 1.1;
    color: #111;
  }
  .craftsmanship-text {
    font-size: 15px;
    line-height: 1.8;
    margin-bottom: 40px;
    color: #444;
  }
  .craftsmanship-btn {
    display: inline-block;
    padding-bottom: 5px;
    color: #111;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-size: 12px;
    border-bottom: 1px solid #111;
    transition: opacity 0.3s ease;
  }
  .craftsmanship-btn:hover {
    opacity: 0.6;
  }
  .placeholder-svg {
    background-color: #f4f4f4;
    fill: #cccccc;
  }

  @media only screen and (max-width: 900px) {
    .craftsmanship-section-{{ section.id }} {
      padding: 60px 0;
    }
    .craftsmanship-container, .craftsmanship-container--reverse {
      flex-direction: column;
      padding: 0 20px;
    }
    .craftsmanship-image-wrapper {
      width: 100%;
    }
    .craftsmanship-image {
      height: 450px;
    }
    .craftsmanship-content-wrapper {
      width: 90%;
      position: relative;
      right: auto;
      left: auto;
      margin-top: -60px;
      padding: 50px 30px;
    }
    .craftsmanship-title {
      font-size: 32px;
    }
  }
{%- endstyle -%}

<div class="craftsmanship-section-{{ section.id }}">
  <div class="craftsmanship-container {% if section.settings.layout == 'right' %}craftsmanship-container--reverse{% endif %}">
    
    <div class="craftsmanship-image-wrapper">
      {%- if section.settings.image != blank -%}
        <img src="{{ section.settings.image | img_url: '1200x' }}" alt="{{ section.settings.title | escape }}" class="craftsmanship-image" loading="lazy">
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg craftsmanship-image' }}
      {%- endif -%}
    </div>

    <div class="craftsmanship-content-wrapper text-{{ section.settings.align_text }}">
      {%- if section.settings.subtitle != blank -%}
        <div class="craftsmanship-subtitle">{{ section.settings.subtitle }}</div>
      {%- endif -%}
      
      {%- if section.settings.title != blank -%}
        <h2 class="craftsmanship-title">{{ section.settings.title }}</h2>
      {%- endif -%}
      
      {%- if section.settings.text != blank -%}
        <div class="craftsmanship-text">{{ section.settings.text }}</div>
      {%- endif -%}
      
      {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
        <a href="{{ section.settings.button_link }}" class="craftsmanship-btn">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Craftsmanship Editorial",
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "label": "Image Alignment",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ]
    },
    {
      "type": "select",
      "id": "align_text",
      "label": "Text Alignment",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ]
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "EST. 1987"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Master Craftsmanship"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Decades of experience go into every piece we create. Our master jewelers blend traditional techniques with modern precision to craft rings that will last a lifetime and beyond.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Our Story"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Craftsmanship Editorial"
    }
  ]
}
{% endschema %}
