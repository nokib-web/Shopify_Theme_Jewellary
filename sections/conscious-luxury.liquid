{%- style -%}
  .conscious-section-{{ section.id }} {
    position: relative;
    padding: 120px 0;
    color: #ffffff;
    overflow: hidden;
  }
  .conscious-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    z-index: 1;
  }
  .conscious-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to right, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.3) 100%);
    z-index: 2;
  }
  .conscious-content {
    position: relative;
    z-index: 3;
    max-width: 600px;
  }
  .conscious-subtitle {
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 3px;
    margin-bottom: 20px;
    color: {{ section.settings.accent_color }};
  }
  .conscious-title {
    font-size: 48px;
    font-family: var(--typeHeaderPrimary), serif;
    margin-bottom: 30px;
    line-height: 1.1;
  }
  .conscious-text {
    font-size: 18px;
    line-height: 1.6;
    margin-bottom: 40px;
    opacity: 0.9;
  }
  .conscious-features {
    display: flex;
    gap: 40px;
  }
  .conscious-feature {
    display: flex;
    align-items: center;
    gap: 15px;
  }
  .conscious-feature-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid {{ section.settings.accent_color }};
    border-radius: 50%;
    color: {{ section.settings.accent_color }};
  }
  .conscious-feature-text {
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: bold;
  }

  @media only screen and (max-width: 768px) {
    .conscious-section-{{ section.id }} {
      padding: 80px 0;
    }
    .conscious-overlay {
      background: rgba(0,0,0,0.6);
    }
    .conscious-title {
      font-size: 36px;
    }
    .conscious-features {
      flex-direction: column;
      gap: 20px;
    }
  }
{%- endstyle -%}

<div class="conscious-section-{{ section.id }}">
  
  {%- if section.settings.image != blank -%}
    <div class="conscious-bg" style="background-image: url('{{ section.settings.image | img_url: '2000x' }}');"></div>
  {%- else -%}
    <div class="conscious-bg" style="background-image: url('{{ 'conscious_diamond.png' | asset_url }}');"></div>
  {%- endif -%}
  
  <div class="conscious-overlay"></div>

  <div class="page-width">
    <div class="conscious-content">
      <div class="conscious-subtitle">{{ section.settings.subtitle }}</div>
      <h2 class="conscious-title">{{ section.settings.title }}</h2>
      <div class="conscious-text">{{ section.settings.text }}</div>
      
      <div class="conscious-features">
        <div class="conscious-feature">
          <div class="conscious-feature-icon">
            <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
          </div>
          <div class="conscious-feature-text">Conflict Free</div>
        </div>
        <div class="conscious-feature">
          <div class="conscious-feature-icon">
            <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
          </div>
          <div class="conscious-feature-text">Recycled Metals</div>
        </div>
      </div>

      {%- if section.settings.button_label != blank -%}
        <div style="margin-top: 40px;">
          <a href="{{ section.settings.button_link | default: '/pages/contact' }}" class="btn">
            {{ section.settings.button_label }}
          </a>
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Conscious Luxury",
  "settings": [
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#d4af37"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Ethical Sourcing"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Conscious Luxury"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>We believe that true luxury shouldn't come at a cost to the earth. Every diamond we source is rigorously vetted to be 100% conflict-free, and we exclusively use recycled precious metals to minimise our environmental footprint.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image (Leave blank to use default)"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Book a VIP Consultation"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Conscious Luxury"
    }
  ]
}
{% endschema %}
