<div class="custom-instafeed-wrapper" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="page-width">
    
    <div class="custom-instafeed-header">
      {%- if section.settings.title != blank -%}
        <h2 class="h2 custom-instafeed-title" style="font-family: var(--typeHeaderPrimary), var(--typeHeaderFallback); text-transform: none; letter-spacing: normal;">
          {{ section.settings.title }}
        </h2>
      {%- endif -%}
      
      {%- if section.settings.subtitle != blank -%}
        <div class="custom-instafeed-subtitle">
          <a href="{{ section.settings.instagram_link }}" target="_blank" rel="noopener">
            &ndash; {{ section.settings.subtitle }}
          </a>
        </div>
      {%- endif -%}
    </div>

    <div class="custom-instafeed-content">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when '@app' -%}
            {% render block %}
        {%- endcase -%}
      {%- endfor -%}
    </div>
    
  </div>
</div>

{% schema %}
{
  "name": "Custom Instafeed Wrapper",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Follow Us"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Follow us @gregoryjewellers"
    },
    {
      "type": "url",
      "id": "instagram_link",
      "label": "Instagram Link"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "default": 60,
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "default": 60,
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "Custom Instafeed Wrapper"
    }
  ]
}
{% endschema %}
