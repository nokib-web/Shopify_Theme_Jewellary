      "name": "Luxury Services",
      "blocks": [
        { "type": "badge", "settings": { "icon": "star", "text": "35+ Years Experience" } },
        { "type": "badge", "settings": { "icon": "shield", "text": "Family Owned" } },
        { "type": "badge", "settings": { "icon": "map-pin", "text": "Sydney Based" } }
