    {
      "type": "header",
      "content": "Button settings"
    },
    {
      "type": "text",
      "id": "primary_btn_label",
      "label": "Button Label",
      "default": "Explore Services"
    },
    {
      "type": "url",
      "id": "primary_btn_link",
      "label": "Button Link"
    },
    {
      "type": "range",
      "id": "btn_radius",
      "label": "Button Border Radius",
      "min": 0, "max": 50, "step": 1, "default": 50
    },
    {
      "type": "color",
      "id": "btn_bg_color",
      "label": "Button Background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Button Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "btn_border_color",
      "label": "Button Border Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "btn_hover_bg",
      "label": "Button Hover Background",
      "default": "#C8A26A"
    },
    {
      "type": "color",
      "id": "btn_hover_text",
      "label": "Button Hover Text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "btn_hover_border",
      "label": "Button Hover Border Color",
      "default": "#C8A26A"
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Main Hero Image"
    },
    {
      "type": "image_picker",
      "id": "float_image_1",
      "label": "Bottom Left Floating Image"
    },
    {
      "type": "image_picker",
      "id": "float_image_2",
      "label": "Top Right Floating Image"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Desktop Padding Top",
      "min": 0, "max": 200, "step": 10, "default": 120
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Desktop Padding Bottom",
      "min": 0, "max": 200, "step": 10, "default": 120
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Mobile Padding Top",
      "min": 0, "max": 100, "step": 5, "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Mobile Padding Bottom",
      "min": 0, "max": 100, "step": 5, "default": 60
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Trust Badge",
      "limit": 4,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "star", "label": "Star" },
            { "value": "shield", "label": "Shield" },
