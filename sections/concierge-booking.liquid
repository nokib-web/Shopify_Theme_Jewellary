{%- style -%}
  .concierge-section-{{ section.id }} {
    padding: 100px 0;
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    text-align: center;
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  .concierge-inner {
    max-width: 700px;
    margin: 0 auto;
  }
  .concierge-icon {
    margin-bottom: 30px;
    color: {{ section.settings.accent_color }};
  }
  .concierge-title {
    font-size: 36px;
    font-family: var(--typeHeaderPrimary), serif;
    margin-bottom: 20px;
    color: {{ section.settings.text_color }};
  }
  .concierge-text {
    font-size: 16px;
    line-height: 1.6;
    margin-bottom: 40px;
    opacity: 0.8;
  }
  .concierge-btn-group {
    display: flex;
    justify-content: center;
    gap: 20px;
  }
  .concierge-btn {
    display: inline-block;
    padding: 15px 40px;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-size: 14px;
    font-weight: bold;
    transition: all 0.3s ease;
  }
  .concierge-btn--primary {
    background-color: {{ section.settings.text_color }};
    color: {{ section.settings.bg_color }};
  }
  .concierge-btn--primary:hover {
    opacity: 0.8;
  }
  .concierge-btn--secondary {
    background-color: transparent;
    color: {{ section.settings.text_color }};
    border: 1px solid {{ section.settings.text_color }};
  }
  .concierge-btn--secondary:hover {
    background-color: {{ section.settings.text_color }};
    color: {{ section.settings.bg_color }};
  }
  @media only screen and (max-width: 768px) {
    .concierge-section-{{ section.id }} {
      padding: 60px 0;
    }
    .concierge-title {
      font-size: 28px;
    }
    .concierge-btn-group {
      flex-direction: column;
      gap: 15px;
    }
  }
{%- endstyle -%}

<div class="concierge-section-{{ section.id }}">
  <div class="page-width">
    <div class="concierge-inner">
      <div class="concierge-icon">
        <svg viewBox="0 0 24 24" width="48" height="48" stroke="currentColor" stroke-width="1" fill="none"><path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"></path><circle cx="12" cy="10" r="3"></circle></svg>
      </div>
      <h2 class="concierge-title">{{ section.settings.title }}</h2>
      <div class="concierge-text">{{ section.settings.text }}</div>
      
      <div class="concierge-btn-group">
        {%- if section.settings.btn_1_label != blank and section.settings.btn_1_link != blank -%}
          <a href="{{ section.settings.btn_1_link }}" class="concierge-btn concierge-btn--primary">
            {{ section.settings.btn_1_label }}
          </a>
        {%- endif -%}
        {%- if section.settings.btn_2_label != blank and section.settings.btn_2_link != blank -%}
          <a href="{{ section.settings.btn_2_link }}" class="concierge-btn concierge-btn--secondary">
            {{ section.settings.btn_2_label }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Concierge Booking",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#d4af37"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Book a VIP Consultation"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Visit our North Rocks boutique or meet with our experts virtually from anywhere in the world. Experience personalized service as we help you find or create the perfect piece.</p>"
    },
    {
      "type": "text",
      "id": "btn_1_label",
      "label": "Button 1 Label",
      "default": "Book In-Store"
    },
    {
      "type": "url",
      "id": "btn_1_link",
      "label": "Button 1 Link"
    },
    {
      "type": "text",
      "id": "btn_2_label",
      "label": "Button 2 Label",
      "default": "Virtual Appointment"
    },
    {
      "type": "url",
      "id": "btn_2_link",
      "label": "Button 2 Link"
    }
  ],
  "presets": [
    {
      "name": "Concierge Booking"
    }
  ]
}
{% endschema %}
